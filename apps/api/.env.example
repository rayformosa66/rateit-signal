# ── Database ──────────────────────────────────────────────────────────────────
# Local dev: relative path to SQLite file.
# Production: use a hosted libsql/Turso URL, e.g. libsql://your-db.turso.io
DATABASE_URL="file:./dev.db"

# ── JWT ───────────────────────────────────────────────────────────────────────
# REQUIRED in production. Server throws at startup if missing when NODE_ENV=production.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="replace-with-a-strong-random-secret"

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the admin dashboard.
# Defaults to * (allow all) when not set — acceptable for local dev only.
# Example: ALLOWED_ORIGINS=https://admin.yourdomain.com
ALLOWED_ORIGINS=

# ── Runtime ───────────────────────────────────────────────────────────────────
# Set to "production" to enable all production-only safety guards.
NODE_ENV=development

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
