{
  "name": "@rateit/api",
  "version": "0.1.0",
  "description": "RateIt API — serves merchant verdicts to the extension and accepts user reports",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node --transpile-only src/server.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "db:migrate": "prisma migrate dev",
    "db:seed": "ts-node --transpile-only prisma/seed.ts",
    "db:reset": "prisma migrate reset --force && ts-node --transpile-only prisma/seed.ts"
  },
  "prisma": {
    "seed": "ts-node --transpile-only prisma/seed.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.17.2",
    "@prisma/adapter-libsql": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@rateit/shared-types": "workspace:*",
    "@rateit/verdict-engine": "workspace:*",
    "dotenv": "^16.6.1",
    "prisma": "^7.6.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
