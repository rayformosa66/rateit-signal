{
  "name": "rateit-signal",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "rateit-signal",
      "workspaces": [
        "apps/*",
        "packages/*"
      ],
      "engines": {
        "node": ">=18",
        "npm": ">=7"
      }
    },
    "apps/admin-web": {
      "name": "@rateit/admin-web",
      "version": "0.1.0",
      "dependencies": {
        "@rateit/shared-types": "*"
      },
      "devDependencies": {
        "typescript": "^5.4.5"
      }
    },
    "apps/api": {
      "name": "@rateit/api",
      "version": "0.1.0",
      "dependencies": {
        "@rateit/shared-types": "*",
        "@rateit/verdict-engine": "*"
      },
      "devDependencies": {
        "typescript": "^5.4.5"
      }
    },
    "apps/extension": {
      "name": "@rateit/extension",
      "version": "0.1.0",
      "dependencies": {
        "@rateit/shared-types": "*"
      },
      "devDependencies": {
        "typescript": "^5.4.5"
      }
    },
    "node_modules/@rateit/admin-web": {
      "resolved": "apps/admin-web",
      "link": true
    },
    "node_modules/@rateit/api": {
      "resolved": "apps/api",
      "link": true
    },
    "node_modules/@rateit/extension": {
      "resolved": "apps/extension",
      "link": true
    },
    "node_modules/@rateit/shared-types": {
      "resolved": "packages/shared-types",
      "link": true
    },
    "node_modules/@rateit/verdict-engine": {
      "resolved": "packages/verdict-engine",
      "link": true
    },
    "node_modules/typescript": {
      "version": "5.9.3",
      "resolved": "https://registry.npmjs.org/typescript/-/typescript-5.9.3.tgz",
      "integrity": "sha512-jl1vZzPDinLr9eUt3J/t7V6FgNEw9QjvBPdysz9KfQDD41fQrC2Y4vKQdiaUpFT4bXlb1RHhLpp8wtm6M5TgSw==",
      "dev": true,
      "license": "Apache-2.0",
      "bin": {
        "tsc": "bin/tsc",
        "tsserver": "bin/tsserver"
      },
      "engines": {
        "node": ">=14.17"
      }
    },
    "packages/shared-types": {
      "name": "@rateit/shared-types",
      "version": "0.1.0",
      "devDependencies": {
        "typescript": "^5.4.5"
      }
    },
    "packages/verdict-engine": {
      "name": "@rateit/verdict-engine",
      "version": "0.1.0",
      "dependencies": {
        "@rateit/shared-types": "*"
      },
      "devDependencies": {
        "typescript": "^5.4.5"
      }
    }
  }
}
